# Supply-chain guardrails. npm 11.17+ is required by package.json.
min-release-age=30
save-exact=true
package-lock=true
engine-strict=true

# Refuse high/critical audit findings and unreviewed install scripts.
audit=true
audit-level=high
strict-allow-scripts=true

# Dependencies must resolve through the npm registry, not git/file/tarball URLs.
allow-git=none
allow-file=none
allow-remote=none
